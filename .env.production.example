# Copy this file to .env.production and replace every deployment-specific value.
NODE_ENV=production

# Public HTTPS origin. Do not include a trailing slash.
APP_ORIGIN=https://images.example.com

# Proxy mode used by install.sh: caddy, cloudflare, external, or none.
OU_PROXY_MODE=caddy
# Bare hostname used by the Caddy https profile. Do not include a scheme or port.
OU_PUBLIC_HOST=images.example.com

# Compose binds Web to loopback so a host reverse proxy can terminate TLS.
WEB_BIND_HOST=127.0.0.1
WEB_BIND_PORT=3000
PORT=3000
API_PORT=4000
API_PROXY_TARGET=http://api:4000

# Persistent Docker volume path used by the API container.
OU_DATA_DIR=/data
OU_STORAGE_QUOTA_BYTES=2147483648

# Required. Generate with: openssl rand -hex 32
OU_SECRET_KEY=

COOKIE_SECURE=true
EXPOSE_DEVELOPMENT_RESET_TOKEN=false

# docker-compose.yml gives the Web container 172.30.10.2 on the internal network.
TRUST_PROXY=true
TRUST_PROXY_ADDRESSES=172.30.10.2/32

# These are probe/configuration inputs only in v1.0.2.
# PostgreSQL and Redis are not active persistence or queue implementations.
DATABASE_URL=
REDIS_URL=
CDN_BASE_URL=

# Optional image tag used by Compose.
OU_IMAGE_TAG=local

# Local HTTP mode:
#   APP_ORIGIN=http://localhost:3000
#   COOKIE_SECURE=false
#   OU_PROXY_MODE=none
#   OU_PUBLIC_HOST=
# Start without --profile https. Web remains available on
# WEB_BIND_HOST:WEB_BIND_PORT and Caddy is not started.
#
# Cloudflare orange-cloud mode:
#   OU_PROXY_MODE=cloudflare
# Keep OU_PUBLIC_HOST unchanged, enable the proxied DNS record, and set
# Cloudflare SSL/TLS mode to Full (strict). Caddy still maintains the
# publicly trusted origin certificate automatically.
