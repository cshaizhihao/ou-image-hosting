#!/usr/bin/env bash

set -Eeuo pipefail

PRODUCT_NAME="OU-Image Hosting"
PRODUCT_CN="欧记图床"
SYSTEM_INSTALL_CONF="/etc/ou-image-hosting/install.conf"
USER_INSTALL_CONF="${XDG_CONFIG_HOME:-${HOME:-/tmp}/.config}/ou-image-hosting/install.conf"
INSTALL_CONF="${OUIH_INSTALL_CONF:-}"
INSTALL_DIR="${OUIH_INSTALL_DIR:-}"
ENV_FILE_NAME="${OUIH_ENV_FILE_NAME:-.env.production}"
INPUT_DEVICE="${INPUT_DEVICE:-/dev/tty}"

if [[ ! -r "$INPUT_DEVICE" ]]; then
  INPUT_DEVICE="/dev/stdin"
fi

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  RESET=$'\033[0m'
  BOLD=$'\033[1m'
  PINK=$'\033[38;5;210m'
  GREEN=$'\033[38;5;114m'
  YELLOW=$'\033[38;5;221m'
  RED=$'\033[38;5;203m'
  GRAY=$'\033[38;5;245m'
else
  RESET=""
  BOLD=""
  PINK=""
  GREEN=""
  YELLOW=""
  RED=""
  GRAY=""
fi

info() {
  printf '%s\n' "${PINK}●${RESET} $*"
}

success() {
  printf '%s\n' "${GREEN}✓${RESET} $*"
}

warning() {
  printf '%s\n' "${YELLOW}!${RESET} $*"
}

fatal() {
  printf '%s\n' "${RED}✕ $*${RESET}" >&2
  exit 1
}

banner() {
  printf '%s\n' "${BOLD}${PINK}OU-Image Hosting · 欧记图床${RESET}"
  printf '%s\n' "${GRAY}漂亮地托管，也轻松地管理。${RESET}"
}

usage() {
  cat <<'EOF'
OU-Image Hosting · 欧记图床 管理命令

用法：
  ouih                         打开交互菜单
  ouih doctor                  检查安装、网络、资源与运行环境
  ouih backup                  停服并创建完整数据卷备份
  ouih restore <备份路径>      校验归档并经二次确认后恢复
  ouih rollback                回退最近一次成功更新前的代码版本
  ouih update                  同步 main，顺序重建并启动
  ouih uninstall               安全卸载，默认保留数据卷
  ouih uninstall --purge-data  卸载并永久删除数据卷
  ouih url                     显示公开访问地址
  ouih dir                     显示安装目录
  ouih status                  显示容器状态
  ouih logs [Compose 参数]     查看日志，例如 ouih logs -f api
  ouih start                   启动服务
  ouih stop                    停止服务
  ouih help                    显示帮助

安装目录发现顺序：
  1. OUIH_INSTALL_DIR 环境变量
  2. 当前脚本所在项目目录
  3. /etc/ou-image-hosting/install.conf 中的 INSTALL_DIR
  4. ~/.config/ou-image-hosting/install.conf 中的 INSTALL_DIR
EOF
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

run_as_root() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    "$@"
  elif command_exists sudo; then
    sudo "$@"
  else
    fatal "自动安装依赖需要管理员权限，请使用 root 或安装 sudo。"
  fi
}

detect_package_manager() {
  local manager
  for manager in apt-get dnf yum pacman zypper apk brew; do
    if command_exists "$manager"; then
      printf '%s' "$manager"
      return 0
    fi
  done
  return 1
}

install_base_packages() {
  local manager=""
  manager="$(detect_package_manager)" ||
    fatal "未识别到受支持的包管理器，请手动安装 Git、curl、OpenSSL 和 coreutils。"

  info "检测到运行环境缺少依赖，正在使用 ${manager} 自动补齐"
  case "$manager" in
    apt-get)
      run_as_root apt-get update
      run_as_root env DEBIAN_FRONTEND=noninteractive \
        apt-get install -y git curl openssl coreutils tar gzip ca-certificates
      ;;
    dnf)
      run_as_root dnf install -y git curl openssl coreutils tar gzip ca-certificates
      ;;
    yum)
      run_as_root yum install -y git curl openssl coreutils tar gzip ca-certificates
      ;;
    pacman)
      run_as_root pacman -Syu --noconfirm --needed \
        git curl openssl coreutils tar gzip ca-certificates
      ;;
    zypper)
      run_as_root zypper --non-interactive install -y \
        git curl openssl coreutils tar gzip ca-certificates
      ;;
    apk)
      run_as_root apk add --no-cache git curl openssl coreutils tar gzip ca-certificates
      ;;
    brew)
      brew install git curl openssl@3 coreutils gnu-tar gzip ca-certificates
      ;;
  esac
}

bootstrap_base_dependencies() {
  local -a missing=()
  local command_name
  for command_name in git curl openssl install tar gzip; do
    if ! command_exists "$command_name"; then
      missing+=("$command_name")
    fi
  done

  if ((${#missing[@]} > 0)); then
    warning "缺少基础依赖：${missing[*]}"
    install_base_packages
  fi

  command_exists git || fatal "Git 自动安装失败，请检查包管理器输出。"
  command_exists curl || fatal "curl 自动安装失败，请检查包管理器输出。"
  command_exists openssl || fatal "OpenSSL 自动安装失败，请检查包管理器输出。"
  command_exists install || fatal "coreutils 自动安装失败，请检查包管理器输出。"
  command_exists tar || fatal "tar 自动安装失败，请检查包管理器输出。"
  command_exists gzip || fatal "gzip 自动安装失败，请检查包管理器输出。"
}

canonical_path() {
  local target="$1"
  if command_exists realpath; then
    realpath "$target"
  elif command_exists readlink; then
    readlink -f "$target"
  else
    (
      cd "$(dirname "$target")"
      printf '%s/%s\n' "$PWD" "$(basename "$target")"
    )
  fi
}

read_install_conf() {
  local config="$1"
  [[ -r "$config" ]] || return 1
  local value
  value="$(
    sed -n \
      -e 's/^[[:space:]]*INSTALL_DIR[[:space:]]*=[[:space:]]*//p' \
      "$config" |
      head -n 1
  )"
  value="${value%$'\r'}"
  if [[ "$value" == \"*\" && "$value" == *\" ]]; then
    value="${value:1:${#value}-2}"
  elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
    value="${value:1:${#value}-2}"
  fi
  [[ -n "$value" ]] || return 1
  printf '%s\n' "$value"
}

looks_like_installation() {
  local directory="$1"
  [[ -d "$directory" &&
     -f "$directory/docker-compose.yml" &&
     -f "$directory/$ENV_FILE_NAME" ]]
}

discover_install_dir() {
  if [[ -n "$INSTALL_DIR" ]]; then
    INSTALL_DIR="$(canonical_path "$INSTALL_DIR")"
  else
    local script_path script_dir candidate configured config
    script_path="$(canonical_path "${BASH_SOURCE[0]}")"
    script_dir="$(dirname "$script_path")"
    candidate="$(dirname "$script_dir")"
    if looks_like_installation "$candidate"; then
      INSTALL_DIR="$candidate"
    else
      if [[ -n "$INSTALL_CONF" ]]; then
        config="$INSTALL_CONF"
        if configured="$(read_install_conf "$config" 2>/dev/null)" &&
           [[ -n "$configured" ]]; then
          INSTALL_DIR="$(canonical_path "$configured")"
        fi
      else
        for config in "$SYSTEM_INSTALL_CONF" "$USER_INSTALL_CONF"; do
          if configured="$(read_install_conf "$config" 2>/dev/null)" &&
             [[ -n "$configured" ]]; then
            INSTALL_CONF="$config"
            INSTALL_DIR="$(canonical_path "$configured")"
            break
          fi
        done
      fi
      if [[ -z "$INSTALL_DIR" ]] && looks_like_installation "$PWD"; then
        INSTALL_DIR="$(canonical_path "$PWD")"
      fi
      [[ -n "$INSTALL_DIR" ]] ||
        fatal "找不到安装目录。请设置 OUIH_INSTALL_DIR，或重新运行安装器修复管理命令。"
    fi
  fi

  looks_like_installation "$INSTALL_DIR" ||
    fatal "目录不是有效的 OU-Image Hosting 安装：${INSTALL_DIR}"
}

env_file() {
  printf '%s/%s\n' "$INSTALL_DIR" "$ENV_FILE_NAME"
}

backup_directory() {
  local directory="${OUIH_BACKUP_DIR:-${INSTALL_DIR}.backups}"
  mkdir -p -- "$directory"
  chmod 700 "$directory" 2>/dev/null || true
  canonical_path "$directory"
}

operations_state_directory() {
  local directory
  directory="$(backup_directory)/.ouih-state"
  mkdir -p -- "$directory"
  chmod 700 "$directory" 2>/dev/null || true
  printf '%s\n' "$directory"
}

write_private_file() {
  local target="$1"
  local value="$2"
  local temporary="${target}.tmp.$$"
  (umask 077 && printf '%s\n' "$value" > "$temporary")
  mv -f -- "$temporary" "$target"
}

compose() {
  (
    cd "$INSTALL_DIR"
    local proxy_mode
    local -a command=(
      docker compose
      --env-file "$ENV_FILE_NAME"
      -f docker-compose.yml
    )
    proxy_mode="$(
      sed -n 's/^OU_PROXY_MODE=//p' "$ENV_FILE_NAME" |
        head -n 1
    )"
    if [[ "$proxy_mode" == "caddy" || "$proxy_mode" == "cloudflare" ]]; then
      command+=(--profile https)
    fi
    "${command[@]}" "$@"
  )
}

refresh_management_command() {
  local source_path self_path
  if [[ "${OUIH_DISABLE_SELF_UPDATE:-false}" == "true" ]]; then
    return 0
  fi
  source_path="$INSTALL_DIR/scripts/ouih"
  if [[ ! -x "$source_path" ]]; then
    return 0
  fi
  self_path="$(canonical_path "${BASH_SOURCE[0]}")"
  if [[ "$self_path" == "$source_path" ]]; then
    return 0
  fi

  if [[ -w "$self_path" || -w "$(dirname "$self_path")" ]]; then
    install -m 0755 "$source_path" "$self_path"
    success "ouih 管理命令已同步到最新版本"
  elif [[ "${EUID:-$(id -u)}" -ne 0 ]] && command_exists sudo; then
    sudo install -m 0755 "$source_path" "$self_path"
    success "ouih 管理命令已同步到最新版本"
  else
    warning "没有权限更新 ${self_path}；应用已更新，但建议重新运行安装器刷新 ouih。"
  fi
}

docker_ready() {
  command_exists docker || fatal "未安装 Docker。请先安装 Docker Engine。"
  docker compose version >/dev/null 2>&1 ||
    fatal "未检测到 Docker Compose v2。"
  if ! docker info >/dev/null 2>&1; then
    if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
      fatal "无法连接 Docker。请将当前用户加入 docker 组，或使用 sudo ouih $*。"
    fi
    fatal "无法连接 Docker 服务，请确认 Docker 已启动。"
  fi
}

confirm_yes() {
  local prompt="$1"
  local answer=""
  printf '%s [y/N]: ' "$prompt" >&2
  IFS= read -r answer < "$INPUT_DEVICE" || true
  [[ "$answer" =~ ^[Yy]$ ]]
}

confirm_phrase() {
  local prompt="$1"
  local expected="$2"
  local answer=""
  printf '%s\n' "$prompt" >&2
  printf '请输入 %s 继续: ' "$expected" >&2
  IFS= read -r answer < "$INPUT_DEVICE" || true
  [[ "$answer" == "$expected" ]]
}

safe_install_dir() {
  local directory="$1"
  [[ "$directory" == /* ]] || fatal "拒绝删除非绝对路径。"
  [[ "$directory" != "/" &&
     "$directory" != "/opt" &&
     "$directory" != "/usr" &&
     "$directory" != "/var" &&
     "$directory" != "${HOME:-/__missing__}" &&
     ${#directory} -ge 12 ]] ||
    fatal "安装目录过于宽泛，拒绝卸载：${directory}"
}

remove_path() {
  local target="$1"
  if [[ ! -e "$target" ]]; then
    return
  fi
  if [[ -w "$target" || -w "$(dirname "$target")" ]]; then
    rm -rf -- "$target"
    return
  fi
  if [[ "${EUID:-$(id -u)}" -ne 0 ]] && command_exists sudo; then
    warning "删除 ${target} 需要管理员权限，即将调用 sudo。"
    sudo rm -rf -- "$target"
    return
  fi
  fatal "没有权限删除 ${target}。请使用 sudo 重新运行。"
}

show_url() {
  local value
  value="$(
    sed -n 's/^APP_ORIGIN=//p' "$(env_file)" |
      head -n 1
  )"
  [[ -n "$value" ]] || fatal "${ENV_FILE_NAME} 中没有 APP_ORIGIN。"
  printf '%s\n' "$value"
}

show_dir() {
  printf '%s\n' "$INSTALL_DIR"
}

env_value() {
  local key="$1"
  local file
  file="$(env_file)"
  [[ -r "$file" ]] || return 0
  sed -n "s/^${key}=//p" "$file" | head -n 1
}

DOCTOR_OK=0
DOCTOR_WARN=0
DOCTOR_FAIL=0

doctor_ok() {
  DOCTOR_OK=$((DOCTOR_OK + 1))
  success "$*"
}

doctor_warn() {
  DOCTOR_WARN=$((DOCTOR_WARN + 1))
  warning "$*"
}

doctor_fail() {
  DOCTOR_FAIL=$((DOCTOR_FAIL + 1))
  printf '%s\n' "${RED}✕ $*${RESET}"
}

origin_host() {
  local origin="$1"
  origin="${origin#*://}"
  origin="${origin%%/*}"
  origin="${origin%%:*}"
  printf '%s\n' "$origin"
}

port_is_listening() {
  local port="$1"
  command_exists ss || return 2
  ss -ltn 2>/dev/null |
    awk -v expected=":${port}" '$4 ~ expected "$" { found=1 } END { exit !found }'
}

doctor_port() {
  local label="$1"
  local port="$2"
  if port_is_listening "$port"; then
    doctor_ok "${label}端口 ${port} 正在监听"
  else
    local status=$?
    if ((status == 2)); then
      doctor_warn "缺少 ss，无法检查${label}端口 ${port}"
    else
      doctor_warn "${label}端口 ${port} 当前未监听"
    fi
  fi
}

doctor_application() {
  DOCTOR_OK=0
  DOCTOR_WARN=0
  DOCTOR_FAIL=0

  local production_env origin proxy_mode public_host web_port host
  production_env="$(env_file)"
  origin="$(env_value APP_ORIGIN)"
  proxy_mode="$(env_value OU_PROXY_MODE)"
  public_host="$(env_value OU_PUBLIC_HOST)"
  web_port="$(env_value WEB_BIND_PORT)"
  web_port="${web_port:-3000}"
  host="$(origin_host "$origin")"

  banner
  printf '\n%s\n' "系统诊断"
  info "安装目录：${INSTALL_DIR}"

  if [[ -r "$production_env" ]]; then
    doctor_ok "生产配置可读取：${production_env}"
  else
    doctor_fail "生产配置不可读取：${production_env}"
  fi
  if [[ -n "$origin" && "$origin" =~ ^https?://[^/]+$ ]]; then
    doctor_ok "公开地址格式正确：${origin}"
  else
    doctor_fail "APP_ORIGIN 缺失或格式无效（应为不带尾部斜杠的完整地址）"
  fi
  case "$proxy_mode" in
    caddy|cloudflare|external|none)
      doctor_ok "代理模式：${proxy_mode}"
      ;;
    *)
      doctor_fail "OU_PROXY_MODE 无效：${proxy_mode:-未设置}"
      ;;
  esac

  if command_exists docker; then
    doctor_ok "Docker 命令可用"
    if docker compose version >/dev/null 2>&1; then
      doctor_ok "Docker Compose v2 可用"
    else
      doctor_fail "Docker Compose v2 不可用"
    fi
    if docker info >/dev/null 2>&1; then
      doctor_ok "Docker 服务可连接"
      if compose config --quiet >/dev/null 2>&1; then
        doctor_ok "Compose 配置校验通过"
      else
        doctor_fail "Compose 配置校验失败"
      fi
      local running_services
      running_services="$(compose ps --status running --services 2>/dev/null || true)"
      for service in api web; do
        if grep -Fx "$service" <<< "$running_services" >/dev/null; then
          doctor_ok "${service} 容器正在运行"
        else
          doctor_warn "${service} 容器未运行"
        fi
      done
      if [[ "$proxy_mode" == "caddy" || "$proxy_mode" == "cloudflare" ]]; then
        if grep -Fx "caddy" <<< "$running_services" >/dev/null; then
          doctor_ok "Caddy 容器正在运行"
          if compose exec -T caddy caddy validate \
            --config /etc/caddy/Caddyfile --adapter caddyfile >/dev/null 2>&1; then
            doctor_ok "Caddy 配置校验通过"
          else
            doctor_fail "Caddy 配置校验失败"
          fi
        else
          doctor_fail "Caddy 容器未运行"
        fi
      fi
    else
      doctor_fail "无法连接 Docker 服务"
    fi
  else
    doctor_fail "未安装 Docker"
  fi

  doctor_port "Web " "$web_port"
  if [[ "$proxy_mode" == "caddy" || "$proxy_mode" == "cloudflare" ]]; then
    doctor_port "HTTP " 80
    doctor_port "HTTPS " 443
    if [[ -r "$INSTALL_DIR/Caddyfile" ]]; then
      doctor_ok "Caddyfile 可读取"
    else
      doctor_fail "Caddyfile 缺失或不可读取"
    fi
    if [[ -n "$public_host" && "$public_host" == "$host" ]]; then
      doctor_ok "OU_PUBLIC_HOST 与公开地址一致"
    else
      doctor_fail "OU_PUBLIC_HOST 与 APP_ORIGIN 主机名不一致"
    fi
  fi

  if [[ -n "$host" ]] && command_exists getent; then
    if getent ahosts "$host" >/dev/null 2>&1; then
      doctor_ok "DNS 可以解析：${host}"
    else
      doctor_fail "DNS 无法解析：${host}"
    fi
  elif [[ -n "$host" ]]; then
    doctor_warn "缺少 getent，无法检查 DNS：${host}"
  fi

  if [[ -n "$origin" ]] && command_exists curl; then
    if curl --silent --show-error --fail --location \
      --connect-timeout 3 --max-time 8 --output /dev/null "$origin"; then
      doctor_ok "公网地址可以访问：${origin}"
    else
      doctor_fail "公网地址访问失败：${origin}"
    fi
    if [[ "$origin" == https://* ]]; then
      doctor_ok "公开地址已使用 HTTPS"
    else
      doctor_warn "公开地址未使用 HTTPS"
    fi
  elif [[ -n "$origin" ]]; then
    doctor_warn "缺少 curl，无法检查公网地址与 HTTPS"
  fi
  if [[ "$proxy_mode" == "cloudflare" ]]; then
    doctor_warn "Cloudflare 模式请在控制台确认小黄云已开启，SSL/TLS 使用 Full (strict)"
  fi

  local configured_version package_version backup_dir latest_backup state_dir recorded_revision
  configured_version="$(head -n 1 "$INSTALL_DIR/VERSION" 2>/dev/null || true)"
  package_version="$(
    sed -n 's/^[[:space:]]*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
      "$INSTALL_DIR/package.json" 2>/dev/null | head -n 1 || true
  )"
  if [[ -n "$configured_version" && "$configured_version" == "$package_version" ]]; then
    doctor_ok "代码版本文件一致：${configured_version}"
  else
    doctor_warn "VERSION 与 package.json 版本不一致或无法读取"
  fi

  backup_dir="${OUIH_BACKUP_DIR:-${INSTALL_DIR}.backups}"
  if [[ -d "$backup_dir" && -w "$backup_dir" ]]; then
    doctor_ok "备份目录可写：${backup_dir}"
    latest_backup="$(find "$backup_dir" -maxdepth 1 -type f -name '*.tar.gz' -print 2>/dev/null | sort | tail -n 1)"
    if [[ -n "$latest_backup" ]]; then
      doctor_ok "最近数据卷备份：${latest_backup}"
    else
      doctor_warn "备份目录中还没有数据卷备份，请运行 ouih backup"
    fi
  elif [[ -e "$backup_dir" ]]; then
    doctor_warn "备份目录不可写：${backup_dir}"
  else
    doctor_warn "尚未创建备份目录，请运行 ouih backup"
  fi
  state_dir="$backup_dir/.ouih-state"
  if [[ -r "$state_dir/update-pending-from" ]]; then
    doctor_warn "发现未完成的更新记录；确认服务状态后可重试 ouih update"
  fi
  if [[ -r "$state_dir/last-update-to" && -d "$INSTALL_DIR/.git" ]]; then
    recorded_revision="$(head -n 1 "$state_dir/last-update-to")"
    if [[ "$(git -C "$INSTALL_DIR" rev-parse HEAD 2>/dev/null || true)" == "$recorded_revision" ]]; then
      doctor_ok "当前 Git 版本与最近成功更新记录一致"
    else
      doctor_warn "当前 Git 版本与最近成功更新记录不一致，ouih rollback 将被保护"
    fi
  fi

  local disk_available_kb memory_available_kb
  disk_available_kb="$(df -Pk "$INSTALL_DIR" 2>/dev/null | awk 'NR==2 { print $4 }')"
  if [[ "$disk_available_kb" =~ ^[0-9]+$ ]]; then
    if ((disk_available_kb >= 1048576)); then
      doctor_ok "可用磁盘空间：$((disk_available_kb / 1024)) MiB"
    else
      doctor_warn "可用磁盘不足 1 GiB：$((disk_available_kb / 1024)) MiB"
    fi
  else
    doctor_warn "无法读取可用磁盘空间"
  fi
  memory_available_kb="$(awk '/^MemAvailable:/ { print $2 }' /proc/meminfo 2>/dev/null || true)"
  if [[ "$memory_available_kb" =~ ^[0-9]+$ ]]; then
    if ((memory_available_kb >= 524288)); then
      doctor_ok "可用内存：$((memory_available_kb / 1024)) MiB"
    else
      doctor_warn "可用内存不足 512 MiB：$((memory_available_kb / 1024)) MiB"
    fi
  else
    doctor_warn "无法读取可用内存"
  fi

  printf '\n%s\n' "诊断摘要：${DOCTOR_OK} 项通过，${DOCTOR_WARN} 项警告，${DOCTOR_FAIL} 项失败。"
  if ((DOCTOR_FAIL > 0)); then
    printf '%s\n' "建议先处理失败项，再运行 ouih doctor 复查。"
    return 1
  fi
  success "未发现阻断运行的问题。"
}

update_recovery_hint() {
  local stage="$1"
  local previous_revision="$2"
  warning "更新在“${stage}”阶段失败，生产配置已恢复并保留。"
  printf '%s\n' "修复原因后可重试：ouih update" >&2
  printf '%s\n' "如更新已完成过且需要回退，请运行：ouih rollback" >&2
  printf '%s\n' "本次更新前代码版本：${previous_revision}" >&2
}

update_application() {
  bootstrap_base_dependencies
  docker_ready update
  [[ -d "$INSTALL_DIR/.git" ]] ||
    fatal "安装目录不是 Git 仓库，无法自动更新。"
  [[ -z "$(git -C "$INSTALL_DIR" status --porcelain)" ]] ||
    fatal "仓库存在未提交修改。请先提交、暂存或清理后再更新。"

  local production_env backup_env previous_revision update_state pending_revision
  production_env="$(env_file)"
  [[ -f "$production_env" ]] ||
    fatal "缺少 ${production_env}，为避免丢失配置已停止更新。"
  backup_env="$(mktemp)"
  cp -p "$production_env" "$backup_env"
  previous_revision="$(git -C "$INSTALL_DIR" rev-parse HEAD)"
  update_state="$(operations_state_directory)"
  pending_revision="$update_state/update-pending-from"
  write_private_file "$pending_revision" "$previous_revision"
  restore_configuration() {
    if [[ -f "$backup_env" ]]; then
      cp -p "$backup_env" "$production_env"
      rm -f "$backup_env"
    fi
  }

  info "检查并同步 main 分支"
  local git_status
  set +e
  git -C "$INSTALL_DIR" fetch --depth 1 origin main &&
    git -C "$INSTALL_DIR" checkout -B main origin/main &&
    git -C "$INSTALL_DIR" reset --hard origin/main
  git_status=$?
  set -e
  restore_configuration
  if ((git_status != 0)); then
    update_recovery_hint "同步 main" "$previous_revision"
    return 1
  fi
  refresh_management_command

  info "校验 Compose 配置"
  if ! compose config --quiet; then
    update_recovery_hint "校验 Compose 配置" "$previous_revision"
    return 1
  fi
  info "低并发顺序构建 API"
  if ! COMPOSE_PARALLEL_LIMIT=1 compose build api; then
    update_recovery_hint "构建 API" "$previous_revision"
    return 1
  fi
  info "低并发顺序构建 Web"
  if ! COMPOSE_PARALLEL_LIMIT=1 compose build web; then
    update_recovery_hint "构建 Web" "$previous_revision"
    return 1
  fi
  info "启动更新后的服务"
  if ! compose up -d; then
    update_recovery_hint "启动服务" "$previous_revision"
    return 1
  fi
  local updated_revision
  updated_revision="$(git -C "$INSTALL_DIR" rev-parse HEAD)"
  write_private_file "$update_state/last-update-to" "$updated_revision"
  mv -f -- "$pending_revision" "$update_state/last-update-from"
  write_private_file "$update_state/last-update-at" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  success "更新完成，现有 ${ENV_FILE_NAME} 已保留。"
}

rollback_application() {
  bootstrap_base_dependencies
  docker_ready rollback
  [[ -d "$INSTALL_DIR/.git" ]] ||
    fatal "安装目录不是 Git 仓库，无法回退。"
  [[ -z "$(git -C "$INSTALL_DIR" status --porcelain)" ]] ||
    fatal "仓库存在未提交修改。请先处理后再回退。"

  local state_dir from_file to_file previous_revision current_revision
  local production_env env_copy rollback_status=0
  state_dir="$(operations_state_directory)"
  from_file="$state_dir/last-update-from"
  to_file="$state_dir/last-update-to"
  [[ -r "$from_file" && -r "$to_file" ]] ||
    fatal "没有可回退的最近成功更新记录。"
  previous_revision="$(head -n 1 "$from_file")"
  current_revision="$(head -n 1 "$to_file")"
  [[ "$previous_revision" =~ ^[0-9a-fA-F]{7,64}$ &&
     "$current_revision" =~ ^[0-9a-fA-F]{7,64}$ ]] ||
    fatal "最近更新记录包含无效 Git revision，拒绝自动回退。"
  [[ "$(git -C "$INSTALL_DIR" rev-parse HEAD)" == "$current_revision" ]] ||
    fatal "当前代码已不在最近更新版本，拒绝自动回退。"
  git -C "$INSTALL_DIR" cat-file -e "${previous_revision}^{commit}" 2>/dev/null ||
    fatal "更新前版本已不在本地 Git 历史中，无法安全回退。"

  warning "即将从 ${current_revision} 回退到 ${previous_revision}；数据卷不会删除。"
  confirm_yes "确认回退最近一次更新？" ||
    fatal "已取消回退，没有修改代码。"
  production_env="$(env_file)"
  env_copy="$(mktemp)"
  cp -p "$production_env" "$env_copy"
  if ! git -C "$INSTALL_DIR" reset --hard "$previous_revision"; then
    cp -p "$env_copy" "$production_env"
    rm -f -- "$env_copy"
    fatal "Git 无法切换到更新前版本，当前服务未变更。"
  fi
  cp -p "$env_copy" "$production_env"

  set +e
  compose config --quiet &&
    COMPOSE_PARALLEL_LIMIT=1 compose build api &&
    COMPOSE_PARALLEL_LIMIT=1 compose build web &&
    compose up -d
  rollback_status=$?
  set -e
  if ((rollback_status != 0)); then
    warning "回退版本构建或启动失败，正在恢复更新后的代码版本。"
    git -C "$INSTALL_DIR" reset --hard "$current_revision" || true
    cp -p "$env_copy" "$production_env"
    compose up -d || true
    rm -f -- "$env_copy"
    fatal "回退失败，已尝试恢复原代码与服务。"
  fi
  cp -p "$env_copy" "$production_env"
  rm -f -- "$env_copy"
  write_private_file "$state_dir/last-rollback" \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ) ${current_revision} -> ${previous_revision}"
  rm -f -- "$from_file" "$to_file"
  success "已回退到 ${previous_revision}，生产配置和数据卷均已保留。"
}

uninstall_application() {
  local purge_data="false"
  while (($# > 0)); do
    case "$1" in
      --purge-data)
        purge_data="true"
        ;;
      *)
        fatal "未知卸载参数：$1"
        ;;
    esac
    shift
  done

  safe_install_dir "$INSTALL_DIR"
  docker_ready uninstall
  warning "即将卸载 ${PRODUCT_NAME}，安装目录：${INSTALL_DIR}"
  if [[ "$purge_data" == "true" ]]; then
    warning "你选择了 --purge-data，所有图片、配置状态和数据卷将永久删除。"
  else
    info "默认保留 Docker 数据卷 ou-image-hosting_ou_data。"
  fi

  confirm_yes "第一次确认：继续卸载？" ||
    fatal "已取消卸载，没有修改任何内容。"
  local phrase="UNINSTALL"
  [[ "$purge_data" == "true" ]] && phrase="PURGE DATA"
  confirm_phrase "第二次确认：此操作不可自动撤销。" "$phrase" ||
    fatal "确认文字不匹配，已取消卸载。"

  if [[ "$purge_data" == "true" ]]; then
    compose down --remove-orphans --volumes
  else
    compose down --remove-orphans
  fi

  if [[ "$purge_data" == "true" ]]; then
    local configured self_path config
    for config in "${INSTALL_CONF:-}" "$SYSTEM_INSTALL_CONF" "$USER_INSTALL_CONF"; do
      [[ -n "$config" && -r "$config" ]] || continue
      configured="$(read_install_conf "$config" 2>/dev/null || true)"
      if [[ "$configured" == "$INSTALL_DIR" ]]; then
        remove_path "$config"
      fi
    done
    self_path="$(canonical_path "${BASH_SOURCE[0]}")"
    remove_path "$INSTALL_DIR"
    if [[ "$self_path" != "$INSTALL_DIR/"* &&
          ("$self_path" == "/usr/local/bin/ouih" ||
           "$self_path" == "${HOME:-/tmp}/.local/bin/ouih") ]]; then
      remove_path "$self_path"
    fi
    success "${PRODUCT_CN} 已卸载，数据卷已永久删除。"
  else
    success "${PRODUCT_CN} 运行环境已卸载。"
    printf '%s\n' "安装目录、生产配置与数据卷均已保留：${INSTALL_DIR}"
    printf '%s\n' "需要恢复时运行：ouih start"
  fi
}

status_application() {
  docker_ready status
  compose ps
}

logs_application() {
  docker_ready logs
  if (($# == 0)); then
    compose logs --tail=200
  else
    compose logs "$@"
  fi
}

start_application() {
  docker_ready start
  compose up -d
  success "${PRODUCT_CN} 已启动。"
}

stop_application() {
  docker_ready stop
  compose stop
  success "${PRODUCT_CN} 已停止。"
}

CREATED_BACKUP_PATH=""

create_volume_backup_archive() {
  local reason="${1:-manual}"
  local directory timestamp revision version archive partial manifest status
  directory="$(backup_directory)"
  timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
  revision="$(git -C "$INSTALL_DIR" rev-parse HEAD 2>/dev/null || printf unknown)"
  version="$(head -n 1 "$INSTALL_DIR/VERSION" 2>/dev/null || printf unknown)"
  archive="$directory/ou-image-hosting-${timestamp}-${reason}-$$.tar.gz"
  partial="${archive}.partial"
  manifest="$directory/.ouih-backup-manifest"
  [[ ! -e "$archive" && ! -e "$partial" ]] ||
    fatal "备份文件已存在，请稍后再试：${archive}"

  (umask 077 && cat > "$manifest" <<EOF
format=ouih-volume-backup-v1
product=OU-Image Hosting
created_at=${timestamp}
reason=${reason}
version=${version}
revision=${revision}
EOF
  )
  info "正在以低优先级单线程归档 ou_data 数据卷"
  set +e
  compose run --rm --no-deps -T --user 0:0 \
    --volume "$directory:/backup:ro" \
    --entrypoint /bin/sh api -c \
    'cd /data && nice -n 10 tar -czf - -C /backup .ouih-backup-manifest -C /data .' \
    > "$partial"
  status=$?
  set -e
  rm -f -- "$manifest"
  if ((status != 0)) || [[ ! -s "$partial" ]]; then
    rm -f -- "$partial"
    return 1
  fi
  chmod 600 "$partial" 2>/dev/null || true
  mv -f -- "$partial" "$archive"
  CREATED_BACKUP_PATH="$archive"
  success "数据卷备份已创建：${archive}"
}

backup_application() {
  bootstrap_base_dependencies
  docker_ready backup
  backup_directory >/dev/null
  info "为获得一致备份，将短暂停止服务"
  compose stop
  local backup_status=0 restart_status=0
  create_volume_backup_archive manual || backup_status=$?
  compose up -d || restart_status=$?
  if ((backup_status != 0)); then
    fatal "备份失败；临时文件已清理，服务已尝试重新启动。"
  fi
  if ((restart_status != 0)); then
    fatal "备份已完成，但服务重新启动失败。请运行 ouih start。"
  fi
}

validate_volume_backup_archive() {
  local archive="$1"
  local max_archive_bytes max_entries max_uncompressed_bytes archive_bytes
  max_archive_bytes="${OUIH_MAX_BACKUP_ARCHIVE_BYTES:-107374182400}"
  max_entries="${OUIH_MAX_BACKUP_ENTRIES:-1000000}"
  max_uncompressed_bytes="${OUIH_MAX_BACKUP_UNCOMPRESSED_BYTES:-214748364800}"
  [[ "$max_archive_bytes" =~ ^[1-9][0-9]*$ &&
     "$max_entries" =~ ^[1-9][0-9]*$ &&
     "$max_uncompressed_bytes" =~ ^[1-9][0-9]*$ ]] ||
    fatal "备份安全预算必须是正整数。"
  if archive_bytes="$(stat -c %s -- "$archive" 2>/dev/null)"; then
    :
  else
    archive_bytes="$(stat -f %z -- "$archive" 2>/dev/null)" ||
      fatal "无法读取备份文件大小。"
  fi
  [[ "$archive_bytes" =~ ^[0-9]+$ ]] || fatal "备份文件大小无效。"
  ((archive_bytes <= max_archive_bytes)) ||
    fatal "备份压缩文件超过安全上限（${max_archive_bytes} bytes）。"

  local listing names
  listing="$(mktemp)"
  names="$(mktemp)"
  if ! tar --numeric-owner -tvzf "$archive" > "$listing" 2>/dev/null ||
     ! tar -tzf "$archive" > "$names" 2>/dev/null; then
    rm -f -- "$listing" "$names"
    fatal "备份 gzip/tar 完整性校验失败：${archive}"
  fi
  if ! awk -v max_entries="$max_entries" \
      -v max_bytes="$max_uncompressed_bytes" '
    BEGIN { entries=0; bytes=0; unsafe=0 }
    {
      type=substr($0, 1, 1)
      if (type != "-" && type != "d") unsafe=1
      entries += 1
      if (type == "-") {
        size=$3
        if (size !~ /^[0-9]+$/) unsafe=1
        else bytes += size
      }
      if (entries > max_entries || bytes > max_bytes) unsafe=1
    }
    END { exit unsafe }
  ' "$listing"; then
    rm -f -- "$listing" "$names"
    fatal "备份含链接/设备/FIFO等特殊条目，或超过条目数/解压字节预算。"
  fi
  if ! awk '
    BEGIN { manifest=0; state=0; unsafe=0 }
    /^\// { unsafe=1 }
    /(^|\/)\.\.($|\/)/ { unsafe=1 }
    { normalized=$0; sub(/^\.\//, "", normalized); if (seen[normalized]++) unsafe=1 }
    normalized == ".ouih-backup-manifest" { manifest=1 }
    normalized == "ou-image.json" { state=1 }
    END { exit !(manifest && state && !unsafe) }
  ' "$names"; then
    rm -f -- "$listing" "$names"
    fatal "备份内容检查失败：缺少标识/状态文件，或包含重复/不安全路径。"
  fi
  rm -f -- "$listing" "$names"
  local manifest
  manifest="$(
    tar -xOzf "$archive" .ouih-backup-manifest 2>/dev/null |
      head -c 65537
  )" ||
    fatal "无法读取备份标识。"
  ((${#manifest} <= 65536)) || fatal "备份标识超过 64 KiB 安全上限。"
  grep -Fx 'format=ouih-volume-backup-v1' <<< "$manifest" >/dev/null ||
    fatal "不支持的备份格式。"
  grep -Fx 'product=OU-Image Hosting' <<< "$manifest" >/dev/null ||
    fatal "归档不属于 OU-Image Hosting。"
}

clear_restore_staging() {
  local staging="$1"
  compose run --rm --no-deps -T --user 0:0 \
    --volume "$staging:/restore-staging" \
    --entrypoint /bin/sh api -c \
    'find /restore-staging -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +' \
    >/dev/null
}

stage_volume_backup_archive() {
  local archive="$1"
  local staging="$2"
  clear_restore_staging "$staging"
  compose run --rm --no-deps -T --user 0:0 \
    --volume "$staging:/restore-staging" \
    --entrypoint /bin/sh api -c \
    'umask 077 && nice -n 10 tar -xzf - -C /restore-staging --no-same-owner --no-same-permissions && test -f /restore-staging/.ouih-backup-manifest && test ! -L /restore-staging/.ouih-backup-manifest && test -f /restore-staging/ou-image.json && test ! -L /restore-staging/ou-image.json && grep -Fx "format=ouih-volume-backup-v1" /restore-staging/.ouih-backup-manifest >/dev/null && grep -Fx "product=OU-Image Hosting" /restore-staging/.ouih-backup-manifest >/dev/null' \
    < "$archive"
}

replace_volume_from_staging() {
  local staging="$1"
  compose run --rm --no-deps -T --user 0:0 \
    --volume "$staging:/restore-staging:ro" \
    --entrypoint /bin/sh api -c \
    'find /data -mindepth 1 -maxdepth 1 -exec rm -rf -- {} + && cp -a /restore-staging/. /data/ && rm -f /data/.ouih-backup-manifest && chown -R 1000:1000 /data'
}

restore_application() {
  (($# == 1)) || fatal "用法：ouih restore <备份路径>"
  bootstrap_base_dependencies
  docker_ready restore
  local archive production_env env_copy safety_backup backup_dir staging restore_status=0
  [[ -f "$1" ]] || fatal "备份文件不存在：$1"
  archive="$(canonical_path "$1")"
  [[ -f "$archive" && -r "$archive" ]] || fatal "备份文件不可读取：${archive}"
  validate_volume_backup_archive "$archive"
  backup_dir="$(backup_directory)"
  warning "恢复会替换当前 ou_data 数据卷中的全部图片、配置状态和历史。"
  confirm_yes "第一次确认：恢复 ${archive}？" ||
    fatal "已取消恢复，没有修改任何数据。"
  confirm_phrase "第二次确认：服务会短暂停止，并先自动创建安全备份。" "RESTORE" ||
    fatal "确认文字不匹配，已取消恢复。"

  staging="$(mktemp -d "$backup_dir/.restore-staging.XXXXXX")"
  chmod 700 "$staging" 2>/dev/null || true
  if ! stage_volume_backup_archive "$archive" "$staging"; then
    clear_restore_staging "$staging" || true
    rmdir "$staging" 2>/dev/null || true
    fatal "备份无法安全解压到隔离目录，当前数据未被修改。"
  fi
  production_env="$(env_file)"
  env_copy="$(mktemp)"
  cp -p "$production_env" "$env_copy"
  compose stop
  if ! create_volume_backup_archive pre-restore; then
    clear_restore_staging "$staging" || true
    rmdir "$staging" 2>/dev/null || true
    cp -p "$env_copy" "$production_env"
    rm -f -- "$env_copy"
    compose up -d || true
    fatal "恢复前安全备份失败，当前数据未被替换。"
  fi
  safety_backup="$CREATED_BACKUP_PATH"
  set +e
  replace_volume_from_staging "$staging"
  restore_status=$?
  set -e
  if ((restore_status != 0)); then
    warning "目标备份恢复失败，正在使用恢复前安全备份回滚数据卷。"
    if stage_volume_backup_archive "$safety_backup" "$staging"; then
      replace_volume_from_staging "$staging" ||
        warning "自动恢复安全备份失败，请保留现场并使用：ouih restore ${safety_backup}"
    else
      warning "无法展开恢复前安全备份，请保留现场并使用：ouih restore ${safety_backup}"
    fi
    clear_restore_staging "$staging" || true
    rmdir "$staging" 2>/dev/null || true
    cp -p "$env_copy" "$production_env"
    rm -f -- "$env_copy"
    compose up -d || true
    fatal "恢复失败，已尝试回滚到操作前数据。"
  fi
  clear_restore_staging "$staging" || true
  rmdir "$staging" 2>/dev/null || true
  cp -p "$env_copy" "$production_env"
  rm -f -- "$env_copy"
  compose up -d || fatal "数据已恢复，但服务启动失败。请运行 ouih start。"
  success "恢复完成；${ENV_FILE_NAME} 保持不变。"
  printf '%s\n' "恢复前安全备份：${safety_backup}"
}

pause_for_menu() {
  local key=""
  printf '\n%s' "按任意键返回上级菜单..." >&2
  IFS= read -r -n 1 key < "$INPUT_DEVICE" || true
  printf '\n' >&2
}

interactive_menu() {
  while true; do
    banner
    cat <<'EOF'

  1) 查看状态
  2) 查看日志
  3) 启动服务
  4) 停止服务
  5) 更新应用
  6) 显示访问地址
  7) 显示安装目录
  8) 卸载应用
  9) 系统诊断
 10) 创建数据备份
 11) 从备份恢复
 12) 回退最近更新
  0) 退出
EOF
    local choice=""
    printf '\n请选择 [0-12]: ' >&2
    if ! IFS= read -r choice < "$INPUT_DEVICE"; then
      success "输入已结束，退出管理工具。"
      return
    fi
    case "$choice" in
      1) status_application ;;
      2) logs_application ;;
      3) start_application ;;
      4) stop_application ;;
      5) update_application ;;
      6) show_url ;;
      7) show_dir ;;
      8) uninstall_application ;;
      9) doctor_application || true ;;
      10) backup_application ;;
      11)
        local restore_path=""
        printf '请输入备份文件绝对路径: ' >&2
        IFS= read -r restore_path < "$INPUT_DEVICE" || true
        restore_application "$restore_path"
        ;;
      12) rollback_application ;;
      0)
        success "已退出管理工具。"
        return
        ;;
      *)
        warning "无效选择：${choice:-空}"
        ;;
    esac
    pause_for_menu
  done
}

main() {
  local command="${1:-menu}"
  if (($# > 0)); then
    shift
  fi
  case "$command" in
    help|-h|--help)
      usage
      return
      ;;
  esac

  discover_install_dir
  case "$command" in
    menu) interactive_menu ;;
    doctor) doctor_application ;;
    backup) backup_application ;;
    restore) restore_application "$@" ;;
    rollback) rollback_application ;;
    update) update_application "$@" ;;
    uninstall) uninstall_application "$@" ;;
    url) show_url ;;
    dir) show_dir ;;
    status) status_application ;;
    logs) logs_application "$@" ;;
    start) start_application ;;
    stop) stop_application ;;
    *) fatal "未知命令：${command}。使用 ouih help 查看帮助。" ;;
  esac
}

main "$@"
